  "vault.commutepilot.body": "<p>\u4e00\u6b3e\u901a\u52e4\u81ea\u52a8\u9a7e\u9a76\u5e94\u7528\u3002\u60a8\u53ea\u9700\u8bbe\u7f6e\u4e00\u6b21\u591a\u6bb5\u884c\u7a0b\u2014\u2014\u706b\u8f66\u3001\u516c\u4ea4\u3001\u51fa\u79df\u8f66\u2014\u2014\u5e94\u7528\u6bcf\u5929\u81ea\u52a8\u6267\u884c\u3002<strong>\u5728\u4ea4\u901a\u5de5\u5177\u4e0a\u7761\u89c9</strong>\uff0c\u901a\u8fc77\u4fe1\u53f7\u4f20\u611f\u5668\u878d\u5408\u95f9\u949f\u5728\u7ad9\u70b9\u9192\u6765\uff0c\u5373\u4f7f\u5728\u5730\u4e0bGPS\u5931\u7075\u4e5f\u80fd\u5de5\u4f5c\u3002\u60a8\u7684\u5496\u5561\u5df2\u9884\u8ba2\u5e76\u4e0e\u60a8\u7684\u5230\u8fbe\u65f6\u95f4\u540c\u6b65\u3002\u60a8\u7684\u51fa\u79df\u8f66\u5df2\u9884\u7ea6\u3002\u60a8\u7684\u6742\u8d27\u5728\u56de\u5bb6\u8def\u4e0a\u6536\u96c6\u3002</p><p>\u521b\u65b0\u6982\u5ff5\u5305\u62ec\uff1a<strong>\u52a8\u6001\u914d\u9001\u5230\u60a8\u9884\u6d4b\u7684\u672a\u6765\u4f4d\u7f6e</strong>\u3001\u4ece\u624b\u673a\u4f20\u611f\u5668\u6570\u636e\u8fdb\u884c\u9690\u5f62\u516c\u4ea4\u6620\u5c04\u3001\u901a\u7528\u9053\u8def\u8868\u9762\u8d28\u91cf\u6620\u5c04\u3001\u4ee5\u53ca\u5728\u4efb\u4f55\u53d8\u5316\u65f6\u91cd\u65b0\u8ba1\u7b97\u6574\u4e2a\u94fe\u6761\u7684\u5ef6\u8fdf\u7ea7\u8054\u5f15\u64ce\u3002</p><div class=\"impact\">\u6ca1\u6709\u73b0\u6709\u5e94\u7528\u7ed3\u5408\u4e86\u8fd9\u4e9b\u80fd\u529b</div>",

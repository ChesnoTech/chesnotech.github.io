  "vault.currency.title": "\u56fd\u5bb6\u6570\u5b57\u8d27\u5e01",
  "vault.currency.sub": "\u63d0\u4ea4\u4e2d\u592e\u94f6\u884c \u00b7 2006",
  "vault.currency.body": "<p>\u4e00\u4e2a<strong>14\u5e74\u5206\u9636\u6bb5\u8ba1\u5212</strong>\uff0c\u5c06\u57c3\u53ca\u4ece\u73b0\u91d1\u8fc7\u6e21\u5230\u6570\u5b57\u652f\u4ed8\u3002\u5305\u62ec\u94f6\u884c\u57fa\u7840\u8bbe\u65bd\u53d8\u66f4\u3001\u5546\u5bb6\u91c7\u7eb3\u7b56\u7565\u548c\u516c\u6c11\u5165\u95e8\u2014\u2014\u4e8e2006\u5e74\u63d0\u4ea4\u7ed9\u57c3\u53ca\u56fd\u5bb6\u94f6\u884c\u548c\u4e2d\u592e\u94f6\u884c\u4ee3\u8868\u3002</p><p>\u8fd9\u662f\u5728<strong>\u6bd4\u7279\u5e01\u4e4b\u524d2\u5e74</strong>\uff0cApple Pay\u4e4b\u524d\u5341\u5e74\uff0c\u4efb\u4f55\u653f\u5e9c\u542f\u52a8CBDC\u8ba1\u5212\u4e4b\u524d15\u5e74\u4ee5\u4e0a\u3002\u8be5\u6982\u5ff5\u51e0\u4e4e\u4e0e\u5f53\u4eca\u4e16\u754c\u6b63\u5728\u6784\u5efa\u7684\u5b8c\u5168\u543b\u5408\u3002</p><div class=\"impact\">\u6784\u601d\u4e8e2006 \u00b7 \u6bd4\u7279\u5e012008 \u00b7 CBDC\u5f00\u59cb\u4e8e~2020</div>",
  "vault.cloaking.title": "\u8d85\u6750\u6599\u9690\u8eab",
  "vault.cloaking.sub": "\u72ec\u7acb\u6784\u601d \u00b7 2006",
  "vault.cloaking.body": "<p>\u6784\u601d\u4e86<strong>\u6750\u6599\u53ef\u4ee5\u4f7f\u5149\u7ed5\u8fc7\u7269\u4f53</strong>\u4ece\u800c\u4f7f\u5176\u9690\u5f62\u7684\u60f3\u6cd5\u3002\u4f5c\u4e3a\u57c3\u53ca\u7684\u5b66\u751f\u72ec\u7acb\u63a8\u5bfc\u51fa\u57fa\u672c\u539f\u7406\u3002</p><p>\u51e0\u4e2a\u6708\u540e\uff0c<strong>\u675c\u514b\u5927\u5b66\u5728\u5b9e\u9a8c\u5ba4\u5c55\u793a\u4e86\u4e16\u754c\u9996\u4e2a\u8d85\u6750\u6599\u9690\u8eab\u8863</strong>\u2014\u2014\u9a8c\u8bc1\u4e86\u5b8c\u5168\u76f8\u540c\u7684\u6982\u5ff5\u3002</p><div class=\"impact\">\u72ec\u7acb\u6982\u5ff5\u88ab\u675c\u514b\u5927\u5b66\u5728\u540c\u5e74\u9a8c\u8bc1</div>",
  "vault.solar.title": "\u592a\u9633\u80fd\u6cf5\u6d66\u6fc0\u5149\u5668",
  "vault.solar.sub": "\u72ec\u7acb\u6784\u601d \u00b7 2006",
  "vault.solar.body": "<p>\u6784\u601d\u4e86\u4e00\u4e2a\u7cfb\u7edf\uff0c<strong>\u901a\u8fc7\u900f\u955c\u548c\u5149\u7ea4\u96c6\u4e2d\u592a\u9633\u5149</strong>\u6765\u6cf5\u6d66\u6fc0\u5149\u4ecb\u8d28\u2014\u2014\u5c06\u539f\u59cb\u592a\u9633\u5149\u8f6c\u5316\u4e3a\u76f8\u5e72\u6fc0\u5149\u80fd\u91cf\uff0c\u65e0\u9700\u7535\u529b\u3002</p><p>\u8fd9\u73b0\u5728\u662f\u5168\u7403\u7814\u7a76\u5b9e\u9a8c\u5ba4<strong>\u6b63\u5728\u79ef\u6781\u5f00\u53d1\u7684\u771f\u5b9e\u6280\u672f</strong>\uff0c\u5e94\u7528\u4e8e\u822a\u5929\u63a8\u8fdb\u3001\u5236\u9020\u548c\u80fd\u6e90\u4f20\u8f93\u3002</p><div class=\"impact\">\u73b0\u5728\u662f\u5168\u7403\u5b9e\u9a8c\u5ba4\u7684\u6d3b\u8dc3\u7814\u7a76\u9886\u57df</div>",
  "footer.quote": "\u6211\u8bbe\u8ba1\u5c1a\u4e0d\u5b58\u5728\u7684\u7cfb\u7edf\u3002\u7136\u540e\u627e\u5230\u6784\u5efa\u5b83\u4eec\u7684\u65b9\u6cd5\u3002",
  "footer.city": "\u83ab\u65af\u79d1",
  "vault.safety.title": "\u793e\u533a\u5b89\u5168\u5e73\u53f0",
  "vault.safety.sub": "\u5931\u7269\u62db\u9886 \u00b7 \u5931\u8e2a\u4eba\u5458 \u00b7 \u72af\u7f6a\u60c5\u62a5 \u00b7 2019",
  "vault.safety.body": "<p>Facebook\u88ab\u7528\u4e8e\u5bfb\u627e\u8d70\u5931\u7684\u5b69\u5b50\u3001\u4e22\u5931\u7684\u94b1\u5305\u3001\u5931\u8e2a\u4eba\u5458\u2014\u2014\u4f46\u5e16\u5b50\u5728\u51e0\u5c0f\u65f6\u5185\u5c31\u88ab\u6dc9\u6ca1\uff0c\u6ca1\u6709\u5730\u7406\u5b9a\u5411\uff0c\u6ca1\u6709\u5e74\u9f84\u8fc7\u6ee4\uff0c\u6ca1\u6709\u6301\u4e45\u6027\u3002<strong>\u793e\u4ea4\u5a92\u4f53\u4e0d\u662f\u4e3a\u5b89\u5168\u800c\u8bbe\u8ba1\u7684\u3002</strong></p><p>\u6211\u8bbe\u8ba1\u4e86\u4e00\u4e2a\u591a\u5c42\u7684\u4e13\u4e1a\u5e73\u53f0\uff1a\u5e26\u6709\u5730\u7406\u5b9a\u5411\u7684<strong>\u6c38\u4e45\u6027\u3001\u53ef\u641c\u7d22\u7684\u5931\u7269\u62db\u9886\u6570\u636e\u5e93</strong>\u3002<strong>\u8d70\u5931\u513f\u7ae5\u5373\u65f6\u8b66\u62a5\u7cfb\u7edf</strong>\u2014\u2014\u6bcd\u4eb2\u5728\u5546\u573a\u62a5\u544a\u5b69\u5b50\u8d70\u5931\uff0c\u5e26\u7167\u7247\u7684\u63a8\u9001\u901a\u77e5\u7acb\u5373\u53d1\u9001\u7ed9\u5730\u7406\u534a\u5f84\u5185\u7684\u6bcf\u4e2a\u7528\u6237\u3002\u6570\u79d2\u5185\u6570\u5343\u53cc\u773c\u775b\u88ab\u6fc0\u6d3b\u3002</p><p>\u8fdb\u4e00\u6b65\uff1a<strong>\u793e\u533a\u60c5\u62a5\u6536\u96c6</strong>\u2014\u2014\u53ef\u7591\u884c\u4e3a\u7684\u533f\u540d\u62a5\u544a\u805a\u5408\u6210\u6a21\u5f0f\u300250\u4eba\u62a5\u544a\u540c\u4e00\u4eba\u7684\u653b\u51fb\u6027\u884c\u4e3a\u2192\u8b66\u65b9\u81ea\u52a8\u6807\u8bb0\u3002\u4ece\u5386\u53f2\u6570\u636e\u4e2d\u8fdb\u884c\u884c\u4e3a\u6a21\u5f0f\u5206\u6790\u4ee5\u52a0\u901f\u72af\u7f6a\u8c03\u67e5\u3002<strong>\u4e0d\u662f\u6307\u63a7\u2014\u2014\u800c\u662f\u52a0\u901f\u6b63\u4e49\u7684\u60c5\u62a5\u3002</strong></p><p>\u7c7b\u4f3c\u4e8eCitizen App\uff08\u4f30\u503c4\u4ebf\u7f8e\u5143\u4ee5\u4e0a\uff09\u5728\u7f8e\u56fd\u505a\u7684\u4e8b\u60c5\uff0c\u4f46\u4e3a\u53d1\u5c55\u4e2d\u56fd\u5bb6\u8bbe\u8ba1\uff0c\u90a3\u91cc\u5b98\u65b9\u7cfb\u7edf\u66f4\u6162\uff0c\u793e\u533a\u624d\u662f\u771f\u6b63\u7684\u5b89\u5168\u7f51\u3002</p><div class=\"impact\">\u8bbe\u8ba1\u4e8e2019 \u00b7 \u7ed3\u5408Citizen App + Amber Alert + \u793e\u533a\u60c5\u62a5</div>",
  "vault.health.title": "\u5168\u7403\u533b\u7597\u60c5\u62a5",
  "vault.health.sub": "\u901a\u7528\u8bb0\u5f55 \u00b7 \u533b\u751f\u6392\u540d \u00b7 \u60a3\u8005\u5339\u914d \u00b7 2019",
  "vault.health.body": "<p>\u4eba\u4eec\u6839\u636e\u865a\u5047\u8bc4\u8bba\u548c\u670b\u53cb\u63a8\u8350\u9009\u62e9\u533b\u751f\u3002<strong>\u6ca1\u6709\u8ddf\u8e2a\u8bca\u65ad\u8d28\u91cf\u3001\u6cbb\u7597\u7ed3\u679c\u6216\u533b\u751f\u8868\u73b0\u7684\u96c6\u4e2d\u7cfb\u7edf</strong>\u3002\u60a3\u8005\u662f\u96f6\u8d23\u4efb\u7684\u968f\u673a\u533b\u7597\u51b3\u7b56\u7684\u53d7\u5bb3\u8005\u3002</p><p>\u6211\u8bbe\u8ba1\u4e86\u4e00\u4e2a\u5e73\u53f0\uff1a\u5168\u7403\u53ef\u8bbf\u95ee\u7684<strong>\u901a\u7528\u533b\u7597\u8bb0\u5f55</strong>\u2014\u2014\u5728\u5916\u56fd\u533b\u9662\u7684\u6e38\u5ba2\uff0c\u533b\u751f\u7acb\u5373\u770b\u5230\u60a8\u7684\u5b8c\u6574\u75c5\u53f2\u3002\u6309\u75c5\u60c5\u7684<strong>\u533b\u751f\u8868\u73b0\u8ddf\u8e2a</strong>\u2014\u2014\u6bcf\u4e2a\u533b\u751f\u6bcf\u4e2a\u6848\u4f8b\u7c7b\u578b\u7684\u6210\u529f\u7387\u3002\u57fa\u4e8e\u5b9e\u9645\u7ed3\u679c\u6570\u636e\u800c\u975e\u8bc4\u8bba\u7684<strong>\u60a3\u8005-\u533b\u751f\u5339\u914d</strong>\u3002</p><p>\u8fd8\u6709\uff1a<strong>\u8bca\u65ad\u8d28\u91cf\u63a7\u5236</strong>\u2014\u2014\u533b\u751f\u5728\u5f00\u5904\u65b9\u524d\u662f\u5426\u8fdb\u884c\u4e86\u9002\u5f53\u7684\u68c0\u67e5\uff1f\u6765\u81ea\u6570\u5341\u4ebf\u805a\u5408\u6848\u4f8b\u7684<strong>\u5168\u7403\u5065\u5eb7\u60c5\u62a5</strong>\u2014\u2014\u54ea\u4e9b\u6cbb\u7597\u5bf9\u54ea\u4e9b\u4eba\u7fa4\u6709\u6548\uff0c\u6d41\u884c\u75c5\u65e9\u671f\u68c0\u6d4b\uff0c\u52a0\u901f\u836f\u7269\u7814\u7a76\u3002</p><p>\u6ca1\u6709\u73b0\u6709\u5e73\u53f0\u7ed3\u5408\u6240\u6709\u8fd9\u4e9b\u5c42\u6b21\u3002Zocdoc\u505a\u9884\u7ea6\u3002Epic\u5728\u4e00\u4e2a\u7f51\u7edc\u5185\u7ba1\u7406\u8bb0\u5f55\u3002\u6ca1\u6709\u4eba\u505a\u5168\u7403\u8868\u73b0\u8ddf\u8e2a+\u60a3\u8005\u5339\u914d+\u8d28\u91cf\u63a7\u5236\u3002</p><div class=\"impact\">\u8bbe\u8ba1\u4e8e2019 \u00b7 \u901a\u7528\u8bb0\u5f55 + \u533b\u751f\u6392\u540d + \u57fa\u4e8e\u7ed3\u679c\u7684\u5339\u914d</div>"
}

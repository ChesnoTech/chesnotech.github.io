  "vault.safety.title": "\u30b3\u30df\u30e5\u30cb\u30c6\u30a3\u5b89\u5168\u30d7\u30e9\u30c3\u30c8\u30d5\u30a9\u30fc\u30e0",
  "vault.safety.sub": "\u904d\u5931\u7269\u30fb\u62fe\u5f97\u7269 \u00b7 \u884c\u65b9\u4e0d\u660e\u8005 \u00b7 \u72af\u7f6a\u60c5\u5831 \u00b7 2019",
  "vault.safety.body": "<p>Facebook\u306f\u884c\u65b9\u4e0d\u660e\u306e\u5b50\u4f9b\u3001\u7d1b\u5931\u3057\u305f\u8ca1\u5e03\u3001\u884c\u65b9\u4e0d\u660e\u8005\u306e\u691c\u7d22\u306b\u4f7f\u308f\u308c\u3066\u3044\u307e\u3059\u304c\u3001\u6295\u7a3f\u306f\u6570\u6642\u9593\u3067\u57cb\u3082\u308c\u3001\u5730\u7406\u7684\u30bf\u30fc\u30b2\u30c6\u30a3\u30f3\u30b0\u306a\u3057\u3001\u5e74\u9f62\u30d5\u30a3\u30eb\u30bf\u30ea\u30f3\u30b0\u306a\u3057\u3001\u6c38\u7d9a\u6027\u306a\u3057\u3002<strong>\u30bd\u30fc\u30b7\u30e3\u30eb\u30e1\u30c7\u30a3\u30a2\u306f\u5b89\u5168\u306e\u305f\u3081\u306b\u8a2d\u8a08\u3055\u308c\u3066\u3044\u307e\u305b\u3093\u3002</strong></p><p>\u79c1\u306f\u8907\u6570\u306e\u30ec\u30a4\u30e4\u30fc\u3092\u6301\u3064\u5c02\u9580\u30d7\u30e9\u30c3\u30c8\u30d5\u30a9\u30fc\u30e0\u3092\u8a2d\u8a08\u3057\u307e\u3057\u305f\uff1a\u5730\u7406\u7684\u30bf\u30fc\u30b2\u30c6\u30a3\u30f3\u30b0\u4ed8\u304d\u306e<strong>\u6c38\u7d9a\u7684\u3067\u691c\u7d22\u53ef\u80fd\u306a\u904d\u5931\u7269\u30c7\u30fc\u30bf\u30d9\u30fc\u30b9</strong>\u3002<strong>\u884c\u65b9\u4e0d\u660e\u306e\u5b50\u4f9b\u306e\u5373\u6642\u30a2\u30e9\u30fc\u30c8\u30b7\u30b9\u30c6\u30e0</strong>\u2014\u2014\u6bcd\u89aa\u304c\u30e2\u30fc\u30eb\u3067\u8ff7\u5b50\u3092\u5831\u544a\u3059\u308b\u3068\u3001\u5199\u771f\u4ed8\u304d\u30d7\u30c3\u30b7\u30e5\u901a\u77e5\u304c\u5730\u7406\u7684\u7bc4\u56f2\u5185\u306e\u5168\u30e6\u30fc\u30b6\u30fc\u306b\u5373\u5ea7\u306b\u9001\u4fe1\u3002\u6570\u79d2\u3067\u6570\u5343\u306e\u76ee\u304c\u6d3b\u6027\u5316\u3002</p><p>\u305d\u308c\u4ee5\u4e0a\u306b\uff1a<strong>\u30b3\u30df\u30e5\u30cb\u30c6\u30a3\u60c5\u5831\u53ce\u96c6</strong>\u2014\u2014\u4e0d\u5be9\u306a\u884c\u52d5\u306e\u533f\u540d\u5831\u544a\u304c\u30d1\u30bf\u30fc\u30f3\u306b\u96c6\u7d04\u3002\u540c\u3058\u4eba\u7269\u306e\u653b\u6483\u7684\u884c\u52d5\u309250\u4eba\u304c\u5831\u544a\u2192\u8b66\u5bdf\u306b\u81ea\u52d5\u30d5\u30e9\u30b0\u3002\u72af\u7f6a\u635c\u67fb\u3092\u52a0\u901f\u3059\u308b\u305f\u3081\u306e\u5c65\u6b74\u30c7\u30fc\u30bf\u304b\u3089\u306e\u884c\u52d5\u30d1\u30bf\u30fc\u30f3\u5206\u6790\u3002<strong>\u544a\u767a\u3067\u306f\u306a\u304f\u2014\u2014\u6b63\u7fa9\u3092\u52a0\u901f\u3059\u308b\u305f\u3081\u306e\u60c5\u5831\u3002</strong></p><p>\u7c73\u56fd\u3067Citizen App\uff084\u5104\u30c9\u30eb\u4ee5\u4e0a\u306e\u8a55\u4fa1\u984d\uff09\u304c\u884c\u3063\u3066\u3044\u308b\u3053\u3068\u3068\u4f3c\u3066\u3044\u307e\u3059\u304c\u3001\u516c\u5f0f\u30b7\u30b9\u30c6\u30e0\u304c\u9045\u304f\u30b3\u30df\u30e5\u30cb\u30c6\u30a3\u304c\u771f\u306e\u30bb\u30fc\u30d5\u30c6\u30a3\u30cd\u30c3\u30c8\u3067\u3042\u308b\u767a\u5c55\u9014\u4e0a\u56fd\u5411\u3051\u306b\u8a2d\u8a08\u3002</p><div class=\"impact\">\u8a2d\u8a082019 \u00b7 Citizen App + Amber Alert + \u30b3\u30df\u30e5\u30cb\u30c6\u30a3\u60c5\u5831\u3092\u7d71\u5408</div>",
  "vault.health.title": "\u30b0\u30ed\u30fc\u30d0\u30eb\u30d8\u30eb\u30b9\u30b1\u30a2\u30a4\u30f3\u30c6\u30ea\u30b8\u30a7\u30f3\u30b9",
  "vault.health.sub": "\u30e6\u30cb\u30d0\u30fc\u30b5\u30eb\u8a18\u9332 \u00b7 \u533b\u5e2b\u30e9\u30f3\u30ad\u30f3\u30b0 \u00b7 \u60a3\u8005\u30de\u30c3\u30c1\u30f3\u30b0 \u00b7 2019",
  "vault.health.body": "<p>\u4eba\u3005\u306f\u507d\u306e\u30ec\u30d3\u30e5\u30fc\u3084\u53cb\u4eba\u306e\u63a8\u85a6\u306b\u57fa\u3065\u3044\u3066\u533b\u5e2b\u3092\u9078\u3073\u307e\u3059\u3002<strong>\u8a3a\u65ad\u306e\u8cea\u3001\u6cbb\u7642\u7d50\u679c\u3001\u533b\u5e2b\u306e\u30d1\u30d5\u30a9\u30fc\u30de\u30f3\u30b9\u3092\u8ffd\u8de1\u3059\u308b\u4e2d\u592e\u30b7\u30b9\u30c6\u30e0\u306f\u5b58\u5728\u3057\u307e\u305b\u3093</strong>\u3002\u60a3\u8005\u306f\u8aac\u660e\u8cac\u4efb\u306e\u306a\u3044\u30e9\u30f3\u30c0\u30e0\u306a\u533b\u7642\u5224\u65ad\u306e\u72a0\u7272\u8005\u3067\u3059\u3002</p><p>\u79c1\u304c\u8a2d\u8a08\u3057\u305f\u30d7\u30e9\u30c3\u30c8\u30d5\u30a9\u30fc\u30e0\uff1a\u4e16\u754c\u4e2d\u3067\u30a2\u30af\u30bb\u30b9\u53ef\u80fd\u306a<strong>\u30e6\u30cb\u30d0\u30fc\u30b5\u30eb\u533b\u7642\u8a18\u9332</strong>\u2014\u2014\u5916\u56fd\u306e\u75c5\u9662\u306b\u3044\u308b\u89b3\u5149\u5ba2\u3001\u533b\u5e2b\u304c\u5373\u5ea7\u306b\u5b8c\u5168\u306a\u5c65\u6b74\u3092\u78ba\u8a8d\u3002\u75be\u60a3\u5225\u306e<strong>\u533b\u5e2b\u30d1\u30d5\u30a9\u30fc\u30de\u30f3\u30b9\u8ffd\u8de1</strong>\u2014\u2014\u30b1\u30fc\u30b9\u30bf\u30a4\u30d7\u5225\u306e\u533b\u5e2b\u3054\u3068\u306e\u6210\u529f\u7387\u3002\u30ec\u30d3\u30e5\u30fc\u3067\u306f\u306a\u304f\u5b9f\u969b\u306e\u7d50\u679c\u30c7\u30fc\u30bf\u306b\u57fa\u3065\u304f<strong>\u60a3\u8005\u30fb\u533b\u5e2b\u30de\u30c3\u30c1\u30f3\u30b0</strong>\u3002</p><p>\u3055\u3089\u306b\uff1a<strong>\u8a3a\u65ad\u54c1\u8cea\u7ba1\u7406</strong>\u2014\u2014\u533b\u5e2b\u306f\u51e6\u65b9\u524d\u306b\u9069\u5207\u306a\u691c\u67fb\u3092\u884c\u3063\u305f\u304b\uff1f\u6570\u5341\u5104\u306e\u96c6\u7d04\u30b1\u30fc\u30b9\u304b\u3089\u306e<strong>\u30b0\u30ed\u30fc\u30d0\u30eb\u30d8\u30eb\u30b9\u30a4\u30f3\u30c6\u30ea\u30b8\u30a7\u30f3\u30b9</strong>\u2014\u2014\u3069\u306e\u4eba\u53e3\u7d71\u8a08\u306b\u3069\u306e\u6cbb\u7642\u304c\u6709\u52b9\u304b\u3001\u30d1\u30f3\u30c7\u30df\u30c3\u30af\u306e\u65e9\u671f\u691c\u51fa\u3001\u88fd\u85ac\u7814\u7a76\u306e\u52a0\u901f\u3002</p><p>\u3053\u308c\u3089\u3059\u3079\u3066\u306e\u30ec\u30a4\u30e4\u30fc\u3092\u7d44\u307f\u5408\u308f\u305b\u305f\u65e2\u5b58\u30d7\u30e9\u30c3\u30c8\u30d5\u30a9\u30fc\u30e0\u306f\u3042\u308a\u307e\u305b\u3093\u3002Zocdoc\u306f\u4e88\u7d04\u3092\u884c\u3044\u307e\u3059\u3002Epic\u306f1\u3064\u306e\u30cd\u30c3\u30c8\u30ef\u30fc\u30af\u5185\u3067\u8a18\u9332\u3092\u7ba1\u7406\u3057\u307e\u3059\u3002\u30b0\u30ed\u30fc\u30d0\u30eb\u30d1\u30d5\u30a9\u30fc\u30de\u30f3\u30b9\u8ffd\u8de1\uff0b\u60a3\u8005\u30de\u30c3\u30c1\u30f3\u30b0\uff0b\u54c1\u8cea\u7ba1\u7406\u3092\u884c\u3046\u3082\u306e\u306f\u8ab0\u3082\u3044\u307e\u305b\u3093\u3002</p><div class=\"impact\">\u8a2d\u8a082019 \u00b7 \u30e6\u30cb\u30d0\u30fc\u30b5\u30eb\u8a18\u9332 + \u533b\u5e2b\u30e9\u30f3\u30ad\u30f3\u30b0 + \u7d50\u679c\u30d9\u30fc\u30b9\u306e\u30de\u30c3\u30c1\u30f3\u30b0</div>"
}

  "vault.commutepilot.body": "<p>\u901a\u52e4\u30aa\u30fc\u30c8\u30d1\u30a4\u30ed\u30c3\u30c8\u30a2\u30d7\u30ea\u3002\u8907\u6570\u533a\u9593\u306e\u65c5\u7a0b\u3092\u4e00\u5ea6\u8a2d\u5b9a\u2014\u2014\u96fb\u8eca\u3001\u30d0\u30b9\u3001\u30bf\u30af\u30b7\u30fc\u2014\u2014\u30a2\u30d7\u30ea\u304c\u6bce\u65e5\u5b9f\u884c\u3002<strong>\u4ea4\u901a\u6a5f\u95a2\u3067\u7720\u308c\u308b</strong>\u3001GPS\u304c\u5931\u6557\u3059\u308b\u5730\u4e0b\u3067\u3082\u52d5\u4f5c\u30597\u4fe1\u53f7\u30bb\u30f3\u30b5\u30fc\u878d\u5408\u30a2\u30e9\u30fc\u30e0\u3067\u505c\u7559\u6240\u3067\u8d77\u304d\u308b\u3002\u30b3\u30fc\u30d2\u30fc\u306f\u4e88\u7d04\u6e08\u307f\u3067\u5230\u7740\u6642\u9593\u306b\u540c\u671f\u3002\u30bf\u30af\u30b7\u30fc\u306f\u4e88\u7d04\u6e08\u307f\u3002\u98df\u6599\u54c1\u306f\u5e30\u5b85\u30eb\u30fc\u30c8\u3067\u53ce\u96c6\u3002</p><p>\u65b0\u898f\u30b3\u30f3\u30bb\u30d7\u30c8\uff1a<strong>\u4e88\u6e2c\u3055\u308c\u305f\u5c06\u6765\u306e\u4f4d\u7f6e\u3078\u306e\u52d5\u7684\u914d\u9054</strong>\u3001\u96fb\u8a71\u30bb\u30f3\u30b5\u30fc\u30c7\u30fc\u30bf\u304b\u3089\u306e\u4e0d\u53ef\u8996\u4ea4\u901a\u30de\u30c3\u30d4\u30f3\u30b0\u3001\u30e6\u30cb\u30d0\u30fc\u30b5\u30eb\u9053\u8def\u8868\u9762\u54c1\u8cea\u30de\u30c3\u30d4\u30f3\u30b0\u3001\u4f55\u304b\u5909\u5316\u3057\u305f\u77ac\u9593\u306b\u30c1\u30a7\u30fc\u30f3\u5168\u4f53\u3092\u518d\u8a08\u7b97\u3059\u308b\u9045\u5ef6\u30ab\u30b9\u30b1\u30fc\u30c9\u30a8\u30f3\u30b8\u30f3\u3002</p><div class=\"impact\">\u3053\u308c\u3089\u306e\u6a5f\u80fd\u3092\u7d44\u307f\u5408\u308f\u305b\u305f\u30a2\u30d7\u30ea\u306f\u5b58\u5728\u3057\u306a\u3044</div>",
  "vault.kidcart.sub": "\u5b50\u4f9b\u5411\u3051\u30de\u30fc\u30b1\u30c3\u30c8\u30d7\u30ec\u30a4\u30b9",
  "vault.kidcart.body": "<p>\u5b50\u4f9b\u5411\u3051\u88fd\u54c1\u306e\u30de\u30fc\u30b1\u30c3\u30c8\u30d7\u30ec\u30a4\u30b9\u2014\u2014\u7af6\u5408\u306b\u306a\u3044\u30ec\u30a4\u30e4\u30fc\u4ed8\u304d\uff1a<strong>\u96e2\u5a5a\u652f\u51fa\u691c\u8a3c</strong>\u3002\u89aa\u304c\u5225\u5c45\u4e2d\u306e\u5834\u5408\u3001\u4e00\u65b9\u306e\u89aa\u304c\u5b50\u4f9b\u306e\u305f\u3081\u306b\u9001\u3063\u305f\u304a\u91d1\u304c\u5b9f\u969b\u306b\u5b50\u4f9b\u306b\u4f7f\u308f\u308c\u3066\u3044\u308b\u304b\u78ba\u8a8d\u3067\u304d\u308b\u3002\u900f\u660e\u306a\u30ec\u30b7\u30fc\u30c8\u3001\u30ab\u30c6\u30b4\u30ea\u8ffd\u8de1\u3001\u627f\u8a8d\u30ef\u30fc\u30af\u30d5\u30ed\u30fc\u3002</p><p><strong>\u5e74\u9f62\u5225\u88fd\u54c1\u30d5\u30a3\u30eb\u30bf\u30ea\u30f3\u30b0</strong>\u3001\u89aa\u306e\u8cfc\u5165\u627f\u8a8d\u3001\u6559\u80b2\u30b3\u30f3\u30c6\u30f3\u30c4\u7d71\u5408\u3082\u542b\u3080\u3002</p><div class=\"impact\">\u4e16\u754c\u4e2d\u306e\u6570\u767e\u4e07\u306e\u96e2\u5a5a\u5bb6\u5ead\u306e\u5b9f\u969b\u306e\u75db\u307f\u306b\u5bfe\u5fdc</div>",
  "vault.lockers.sub": "\u30ec\u30b9\u30c8\u30e9\u30f3\u30a4\u30f3\u30d5\u30e9",
  "vault.lockers.body": "<p>\u30ec\u30b9\u30c8\u30e9\u30f3\u7528\u30c0\u30d6\u30eb\u30c9\u30a2\u30ed\u30c3\u30ab\u30fc\uff1a\u30ad\u30c3\u30c1\u30f3\u304c\u80cc\u9762\u304b\u3089\u30bb\u30c3\u30c8\u3001\u5ba2\u304c\u6b63\u9762\u304b\u3089\u53d7\u3051\u53d6\u308b\u3002<strong>\u6e29\u5ea6\u7ba1\u7406\u4ed8\u304d</strong>\u2014\u2014\u6e29\u304b\u3044\u98df\u3079\u7269\u306f\u52a0\u71b1\u3001\u51b7\u305f\u3044\u3082\u306e\u306f\u51b7\u5374\u3002\u4eba\u9593\u306e\u5bfe\u5fdc\u4e0d\u8981\u3002\u5f85\u3061\u6642\u9593\u306a\u3057\u3002</p><p>\u30ec\u30b9\u30c8\u30e9\u30f3\u306e\u30ad\u30c3\u30c1\u30f3\u3068\u53d7\u3051\u53d6\u308a/\u914d\u9054\u306e\u30ae\u30e3\u30c3\u30d7\u306e\u305f\u3081\u306b\u8a2d\u8a08\u3002\u5f85\u3061\u6642\u9593\u3092\u524a\u6e1b\u3001\u6ce8\u6587\u306e\u53d6\u308a\u9055\u3048\u3092\u89e3\u6d88\u300124/7\u7a3c\u50cd\u3002</p><p><em>\u30dc\u30fc\u30ca\u30b9\u6a5f\u80fd#126\u2014\u2014\u5a18\u306e\u30a2\u30a4\u30c7\u30a2\uff1a\u6ce8\u6587\u304c\u6e96\u5099\u3067\u304d\u305f\u3089\u5ea7\u5e2d\u304c\u632f\u52d5\u3002</em></p><div class=\"impact\">\u30ec\u30b9\u30c8\u30e9\u30f3\u306e\u53d7\u3051\u53d6\u308a\u3092\u81ea\u8ca9\u6a5f\u4f53\u9a13\u306b\u5909\u63db</div>",
  "vault.currency.title": "\u56fd\u5bb6\u30c7\u30b8\u30bf\u30eb\u901a\u8ca8",
  "vault.currency.sub": "\u4e2d\u592e\u9280\u884c\u306b\u63d0\u793a \u00b7 2006",
  "vault.currency.body": "<p><strong>14\u5e74\u306e\u6bb5\u968e\u7684\u8a08\u753b</strong>\u3067\u30a8\u30b8\u30d7\u30c8\u3092\u73fe\u91d1\u304b\u3089\u30c7\u30b8\u30bf\u30eb\u6c7a\u6e08\u306b\u79fb\u884c\u3002\u9280\u884c\u30a4\u30f3\u30d5\u30e9\u306e\u5909\u66f4\u3001\u52a0\u76df\u5e97\u63a1\u7528\u6226\u7565\u3001\u5e02\u6c11\u306e\u30aa\u30f3\u30dc\u30fc\u30c7\u30a3\u30f3\u30b0\u3092\u542b\u3080\u2014\u20142006\u5e74\u306b\u30a8\u30b8\u30d7\u30c8\u56fd\u7acb\u9280\u884c\u3068\u4e2d\u592e\u9280\u884c\u306e\u4ee3\u8868\u306b\u63d0\u793a\u3002</p><p>\u3053\u308c\u306f<strong>\u30d3\u30c3\u30c8\u30b3\u30a4\u30f3\u306e2\u5e74\u524d</strong>\u3001Apple Pay\u306e10\u5e74\u524d\u3001\u3044\u304b\u306a\u308b\u653f\u5e9c\u306eCBDC\u30d7\u30ed\u30b0\u30e9\u30e0\u3088\u308a15\u5e74\u4ee5\u4e0a\u524d\u3002\u3053\u306e\u30b3\u30f3\u30bb\u30d7\u30c8\u306f\u3001\u4eca\u65e5\u4e16\u754c\u304c\u69cb\u7bc9\u3057\u3066\u3044\u308b\u3082\u306e\u3068\u307b\u307c\u6b63\u78ba\u306b\u4e00\u81f4\u3002</p><div class=\"impact\">\u69cb\u60f32006 \u00b7 \u30d3\u30c3\u30c8\u30b3\u30a4\u30f32008 \u00b7 CBDC\u958b\u59cb~2020</div>",
  "vault.cloaking.title": "\u30e1\u30bf\u30de\u30c6\u30ea\u30a2\u30eb\u30af\u30ed\u30fc\u30ad\u30f3\u30b0",
  "vault.cloaking.sub": "\u72ec\u7acb\u69cb\u60f3 \u00b7 2006",
  "vault.cloaking.body": "<p><strong>\u6750\u6599\u304c\u7269\u4f53\u306e\u5468\u308a\u306e\u5149\u3092\u66f2\u3052\u308b</strong>\u3053\u3068\u3067\u4e0d\u53ef\u8996\u306b\u3059\u308b\u30a2\u30a4\u30c7\u30a2\u3092\u69cb\u60f3\u3002\u30a8\u30b8\u30d7\u30c8\u306e\u5b66\u751f\u3068\u3057\u3066\u72ec\u7acb\u306b\u57fa\u672c\u539f\u7406\u3092\u5c0e\u51fa\u3002</p><p>\u6570\u30f6\u6708\u5f8c\u3001<strong>\u30c7\u30e5\u30fc\u30af\u5927\u5b66\u304c\u4e16\u754c\u521d\u306e\u30e1\u30bf\u30de\u30c6\u30ea\u30a2\u30eb\u30af\u30ed\u30fc\u30af\u3092\u5b9f\u8a3c</strong>\u2014\u2014\u307e\u3063\u305f\u304f\u540c\u3058\u30b3\u30f3\u30bb\u30d7\u30c8\u3092\u691c\u8a3c\u3002</p><div class=\"impact\">\u72ec\u7acb\u69cb\u60f3\u304c\u540c\u5e74\u306b\u30c7\u30e5\u30fc\u30af\u5927\u5b66\u306b\u3088\u308a\u691c\u8a3c</div>",
  "vault.solar.title": "\u592a\u967d\u5149\u30dd\u30f3\u30d7\u30ec\u30fc\u30b6\u30fc",
  "vault.solar.sub": "\u72ec\u7acb\u69cb\u60f3 \u00b7 2006",
  "vault.solar.body": "<p><strong>\u30ec\u30f3\u30ba\u3068\u5149\u30d5\u30a1\u30a4\u30d0\u30fc\u3067\u592a\u967d\u5149\u3092\u96c6\u4e2d</strong>\u3057\u3066\u30ec\u30fc\u30b6\u30fc\u5a92\u8cea\u3092\u30dd\u30f3\u30d4\u30f3\u30b0\u3059\u308b\u30b7\u30b9\u30c6\u30e0\u3092\u69cb\u60f3\u2014\u2014\u751f\u306e\u592a\u967d\u5149\u3092\u96fb\u6c17\u306a\u3057\u3067\u30b3\u30d2\u30fc\u30ec\u30f3\u30c8\u30ec\u30fc\u30b6\u30fc\u30a8\u30cd\u30eb\u30ae\u30fc\u306b\u5909\u63db\u3002</p><p>\u3053\u308c\u306f\u73fe\u5728\u3001\u5b87\u5b99\u63a8\u9032\u3001\u88fd\u9020\u3001\u30a8\u30cd\u30eb\u30ae\u30fc\u4f1d\u9001\u306e\u305f\u3081\u306b\u4e16\u754c\u4e2d\u306e\u7814\u7a76\u5ba4\u3067<strong>\u7a4d\u6975\u7684\u306b\u958b\u767a\u4e2d\u306e\u5b9f\u969b\u306e\u6280\u8853</strong>\u3067\u3059\u3002</p><div class=\"impact\">\u73fe\u5728\u3001\u4e16\u754c\u4e2d\u306e\u7814\u7a76\u5ba4\u306e\u30a2\u30af\u30c6\u30a3\u30d6\u306a\u7814\u7a76\u5206\u91ce</div>",
  "footer.quote": "\u307e\u3060\u5b58\u5728\u3057\u306a\u3044\u30b7\u30b9\u30c6\u30e0\u3092\u8a2d\u8a08\u3059\u308b\u3002\u305d\u3057\u3066\u305d\u308c\u3092\u69cb\u7bc9\u3059\u308b\u65b9\u6cd5\u3092\u898b\u3064\u3051\u308b\u3002",

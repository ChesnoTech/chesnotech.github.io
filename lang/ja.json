  "thinking1.title": "\u79c1\u306e\u30d7\u30ed\u30bb\u30b9\uff1a\u5230\u7740 \u2192 \u89b3\u5bdf \u2192 \u518d\u69cb\u7bc9 \u2192 \u69cb\u7bc9",
  "thinking1.sub": "\u30de\u30b9\u30bf\u30fc\u30d1\u30bf\u30fc\u30f3 \u00b7 \u3059\u3079\u3066\u306e\u4ed5\u4e8b \u00b7 20\u5e74",
  "thinking1.body": "<div class=\"story-label\">\u30b5\u30a4\u30af\u30eb</div><p>20\u5e74\u9593\u3001\u3059\u3079\u3066\u306e\u5f79\u5272\u3067\u540c\u3058\u30b5\u30a4\u30af\u30eb\u304c\u7e70\u308a\u8fd4\u3055\u308c\u307e\u3059\uff1a\u79c1\u306f<strong>\u65b0\u3057\u3044\u74b0\u5883\u306b\u5165\u308b</strong>\u3001\u4eee\u5b9a\u306a\u3057\u3067\u3002\u5b9f\u969b\u306e\u4ed5\u4e8b\u306b\u53d6\u308a\u7d44\u307f\u3001\u6469\u64e6\u3092\u611f\u3058\u308b\u3002\u305d\u3057\u3066\u79c1\u306e\u5934\u304c\u5206\u6790\u3092\u59cb\u3081\u308b\uff1a<strong>\u306a\u305c\u9045\u3044\uff1f\u306a\u305c\u58ca\u308c\u308b\uff1f\u30dc\u30c8\u30eb\u30cd\u30c3\u30af\u306f\u3069\u3053\uff1f</strong></p><p>\u6469\u64e6\u3092\u898b\u3064\u3051\u305f\u3089\u3001\u7121\u8996\u3067\u304d\u306a\u304f\u306a\u308b\u3002\u5225\u306e\u30ef\u30fc\u30af\u30d5\u30ed\u30fc\u3092\u60f3\u50cf\u3057\u59cb\u3081\u308b\u2014\u2014\u3088\u308a\u826f\u3044\u54c1\u8cea\u3001\u3088\u308a\u901f\u3044\u30b9\u30d4\u30fc\u30c9\u3001\u3088\u308a\u8ad6\u7406\u7684\u306a\u69cb\u9020\u3002\u305d\u3057\u3066<strong>\u6280\u8853\u304c\u30ae\u30e3\u30c3\u30d7\u3092\u57cb\u3081\u308b\u65b9\u6cd5</strong>\u3092\u7814\u7a76\u3059\u308b\u3002</p><div class=\"story-label\">\u8a3c\u62e0\u2014\u2014\u3059\u3079\u3066\u306e\u4ed5\u4e8b</div><p><strong>IM Solutions\uff1a</strong>\u30b3\u30fc\u30eb\u30bb\u30f3\u30bf\u30fc\u306b\u5230\u7740 \u2192 \u30db\u30b9\u30c6\u30a3\u30f3\u30b0\u30c1\u30fc\u30e0\u306e\u82e6\u6226\u3092\u76ee\u6483 \u2192 \u591c\u9593\u306b\u30b5\u30fc\u30d0\u30fc\u3092\u72ec\u5b66 \u2192 1\u30f6\u6708\u304b\u304b\u308b\u30b5\u30a4\u30c8\u30925\u65e5\u3067\u5b8c\u6210</p><p><strong>TMT\u30a8\u30b8\u30d7\u30c8\uff1a</strong>\u30aa\u30da\u30ec\u30fc\u30b7\u30e7\u30f3\u306b\u5230\u7740 \u2192 \u30b3\u30b9\u30c8\u53ef\u8996\u6027\u30bc\u30ed \u2192 \u30aa\u30fc\u30ca\u30fc\u304c\u4e0d\u53ef\u80fd\u3068\u3044\u3063\u305fExcel\u8ffd\u8de1\u3092\u69cb\u7bc9 \u2192 \u7d66\u4e0e\u4ee5\u4e0a\u3092\u7bc0\u7d04</p><p><strong>AI\u30c8\u30ec\u30fc\u30cb\u30f3\u30b0\uff1a</strong>\u30c8\u30e9\u30f3\u30b9\u30af\u30e9\u30a4\u30d0\u30fc\u3068\u3057\u3066\u5230\u7740 \u2192 1-2\u9031\u9593\u306e\u30ec\u30d3\u30e5\u30fc\u30b5\u30a4\u30af\u30eb \u2192 \u81ea\u5df1\u5b66\u7fd2QA\u30b7\u30b9\u30c6\u30e0\u3092\u69cb\u7bc9 \u2192 \u54c1\u8cea\u30fb\u751f\u7523\u6027\u7b2c1\u4f4d</p><p><strong>PC\u4f1a\u793e\uff1a</strong>\u7d44\u307f\u7acb\u3066\u306b\u5230\u7740 \u2192 \u6700\u9069\u5316\u3055\u308c\u3066\u3044\u306a\u3044\u30bd\u30d5\u30c8\u30a6\u30a7\u30a2 \u2192 \u30a2\u30af\u30c6\u30a3\u30d9\u30fc\u30b7\u30e7\u30f3\u30b7\u30b9\u30c6\u30e0\u3001\u4fa1\u683c\u76e3\u8996\u3001\u30b5\u30dd\u30fc\u30c8\u30bd\u30d5\u30c8\u3092\u6ce8\u6587\u8ffd\u8de1\u306b\u8ee2\u7528</p><p><strong>\u6bce\u65e5\u306e\u901a\u52e4\uff1a</strong>\u75b2\u308c\u308b\u6469\u64e6\u3092\u7d4c\u9a13 \u2192 \u65c5\u306e\u30aa\u30fc\u30c8\u30d1\u30a4\u30ed\u30c3\u30c8\u3092\u60f3\u50cf \u2192 CommutePilot\u3092\u8a2d\u8a08</p><div class=\"impact\">\u30b7\u30b9\u30c6\u30e0\u306b\u5165\u308b\u3002\u58ca\u308c\u3066\u3044\u308b\u3082\u306e\u3092\u898b\u308b\u3002\u305d\u308c\u3092\u4fee\u5fa9\u3059\u308b\u3082\u306e\u3092\u4f5c\u308b\u3002</div>",
  "thinking2.title": "\u30b7\u30b9\u30c6\u30e0\u304c\u5b58\u5728\u3059\u308b\u524d\u306b\u305d\u308c\u3092\u898b\u308b",
  "thinking2.sub": "\u30d1\u30bf\u30fc\u30f3\u8a8d\u8b58 \u00b7 2006",
  "thinking2.body": "<div class=\"story-label\">\u305d\u306e\u77ac\u9593</div><p><strong>2006\u5e74</strong>\u3001\u5927\u5b66\u751f\u3068\u3057\u3066\u3001\u30a8\u30b8\u30d7\u30c8\u7d4c\u6d4e\u5168\u4f53\u304c14\u5e74\u3067\u73fe\u91d1\u304b\u3089\u30c7\u30b8\u30bf\u30eb\u306b\u79fb\u884c\u3059\u308b\u30ed\u30fc\u30c9\u30de\u30c3\u30d7\u3092\u4f5c\u6210\u3002\u9280\u884c\u30a4\u30f3\u30d5\u30e9\u3068\u52a0\u76df\u5e97\u63a1\u7528\u3092\u542b\u3080<strong>\u5b8c\u5168\u306a\u6bb5\u968e\u7684\u8a08\u753b</strong>\u3002</p><p><strong>\u30a8\u30b8\u30d7\u30c8\u4e2d\u592e\u9280\u884c</strong>\u306b\u63d0\u793a\u3002\u4f55\u3082\u8d77\u3053\u3089\u306a\u304b\u3063\u305f\u30022\u5e74\u5f8c\u3001<strong>\u30d3\u30c3\u30c8\u30b3\u30a4\u30f3\u304c\u8a95\u751f</strong>\u300210\u5e74\u5f8c\u3001\u3059\u3079\u3066\u306e\u4e2d\u592e\u9280\u884c\u304cCBDC\u30d7\u30ed\u30b0\u30e9\u30e0\u3092\u958b\u59cb\u3002</p><p>\u540c\u6642\u671f\uff1a\u72ec\u7acb\u3057\u3066<strong>\u30e1\u30bf\u30de\u30c6\u30ea\u30a2\u30eb\u30af\u30ed\u30fc\u30ad\u30f3\u30b0</strong>\uff08\u30c7\u30e5\u30fc\u30af\u5927\u5b66\u304c\u6570\u30f6\u6708\u5f8c\u306b\u5b9f\u8a3c\uff09\u3068<strong>\u592a\u967d\u5149\u30dd\u30f3\u30d7\u30ec\u30fc\u30b6\u30fc</strong>\uff08\u73fe\u5728\u306e\u5b9f\u6280\u8853\uff09\u3092\u69cb\u60f3\u3002</p><div class=\"impact\">\u30d1\u30bf\u30fc\u30f3\uff1a\u30a2\u30a4\u30c7\u30a2\u306f\u5e02\u5834\u3088\u308a10\u301c20\u5e74\u65e9\u304f\u5230\u9054</div>",
  "thinking3.title": "\u30bc\u30ed\u304b\u3089\u81ea\u5df1\u5b66\u7fd2\u30b7\u30b9\u30c6\u30e0\u3092\u69cb\u7bc9",
  "thinking3.sub": "\u30b7\u30b9\u30c6\u30e0\u601d\u8003 \u00b7 AI\u30c8\u30ec\u30fc\u30cb\u30f3\u30b0",
  "thinking3.body": "<div class=\"story-label\">\u554f\u984c</div><p>AI\u30c8\u30ec\u30fc\u30cb\u30f3\u30b0\u7528\u306e\u30a2\u30e9\u30d3\u30a2\u8a9e\u6587\u5b57\u8d77\u3053\u3057\u3002\u5404\u30d5\u30a1\u30a4\u30eb\uff1a\u6587\u5b57\u8d77\u3053\u3057 \u2192 \u30a2\u30c3\u30d7\u30ed\u30fc\u30c9 \u2192 \u5f85\u6a5f \u2192 \u76e3\u67fb\u54e1\u304c\u30df\u30b9\u767a\u898b \u2192 \u3084\u308a\u76f4\u3057\u3002<strong>1\u30d5\u30a1\u30a4\u30eb\uff1a1\u301c2\u9031\u9593\u3002</strong></p><div class=\"story-label\">\u79c1\u306e\u89e3\u6c7a\u7b56</div><p>Excel\u3067<strong>\u81ea\u5df1\u5b66\u7fd2QA\u30b7\u30b9\u30c6\u30e0</strong>\u3092\u69cb\u7bc9\u3002\u3059\u3079\u3066\u306e\u30a8\u30e9\u30fc\u3092\u5165\u529b\u3002\u30b7\u30fc\u30c8\u304c\u65e2\u77e5\u306e\u30d1\u30bf\u30fc\u30f3\u3068\u81ea\u52d5\u7167\u5408\u3002</p><p><strong>\u7cbe\u5ea699%\u3002\u751f\u7523\u6027\u7b2c1\u4f4d\u3002</strong>\u5171\u6709\u3057\u3088\u3046\u3068\u3057\u305f\u304c\u3001\u30c1\u30fc\u30e0\u306f\u4fe1\u3058\u3089\u308c\u306a\u304b\u3063\u305f\u3002</p><div class=\"impact\">\u30d1\u30bf\u30fc\u30f3\uff1a\u8ab0\u304b\u306b\u983c\u307e\u308c\u308b\u524d\u306b\u54c1\u8cea\u3092\u81ea\u52d5\u5316</div>",
  "thinking4.title": "\u65e2\u5b58\u306e\u30c4\u30fc\u30eb\u3067\u300c\u4e0d\u53ef\u80fd\u300d\u306a\u554f\u984c\u3092\u89e3\u6c7a",
  "thinking4.sub": "\u5275\u9020\u7684\u554f\u984c\u89e3\u6c7a \u00b7 TMT",
  "thinking4.body": "<div class=\"story-label\">\u300c\u4e0d\u53ef\u80fd\u300d\u306a\u554f\u984c</div><p>\u30aa\u30fc\u30ca\u30fc\u306f\u30d7\u30ed\u30b8\u30a7\u30af\u30c8\u3054\u3068\u306e\u4eba\u4ef6\u8cbb\u304c\u5fc5\u8981\u3060\u3063\u305f\u3002\u4f5c\u696d\u54e1\u306f\u6bce\u65e5\u73fe\u5834\u3092\u79fb\u52d5\u3002<strong>\u300c\u8a08\u7b97\u4e0d\u53ef\u80fd\u3002\u300d</strong></p><div class=\"story-label\">\u79c1\u306e\u30a2\u30d7\u30ed\u30fc\u30c1</div><p>Excel\u3067\u76e3\u7763\u30c7\u30fc\u30bf\u3092\u4f7f\u3063\u3066\u4f5c\u696d\u54e1\u306e\u6642\u9593\u3092\u914d\u5206\u3002\u30bc\u30ed\u304b\u3089<strong>\u6b63\u78ba\u306a\u30b3\u30b9\u30c8\u5185\u8a33</strong>\u3078\u3002\u6700\u521d\u306e\u76e3\u67fb\u3067\u5927\u5e45\u306a\u904e\u6255\u3044\u3092\u767a\u898b\u3002</p><p>\u305d\u306e\u5f8c\uff1a\u30b9\u30de\u30fc\u30c8\u30db\u30fc\u30e0\u306e\u4ee3\u66ff\u54c1\u3092<strong>70\u301c80%\u5b89\u304f</strong>\u3001\u3088\u308a\u591a\u304f\u306e\u6a5f\u80fd\u3067\u63d0\u4f9b\u3002PC\u4f1a\u793e\u3067\u306f\u3001IT\u30b5\u30dd\u30fc\u30c8\u30bd\u30d5\u30c8\u3092<strong>\u6ce8\u6587\u5c65\u884c\u30c8\u30e9\u30c3\u30ab\u30fc</strong>\u306b\u8ee2\u7528\u2014\u2014\u30b5\u30dd\u30fc\u30c8\u30ea\u30af\u30a8\u30b9\u30c8\u3068\u6ce8\u6587\u306e\u8ffd\u8de1\u306f\u540c\u3058\u30ef\u30fc\u30af\u30d5\u30ed\u30fc\u3060\u304b\u3089\u3002</p><div class=\"impact\">\u30d1\u30bf\u30fc\u30f3\uff1a\u30c4\u30fc\u30eb\u306f\u5b58\u5728\u3059\u308b\u3002\u79c1\u306f\u5225\u306e\u4f7f\u3044\u65b9\u3092\u898b\u3064\u3051\u308b\u3002</div>",
  "thinking5.title": "\u8ab0\u3082\u6c42\u3081\u306a\u304f\u3066\u3082\u54c1\u8cea\u3092\u5b88\u308b",
  "thinking5.sub": "\u5012\u7406 \u00b7 AI\u696d\u754c",
  "thinking5.body": "<div class=\"story-label\">\u767a\u898b\u3057\u305f\u3053\u3068</div><p><strong>\u5f71\u306e\u7d4c\u6d08</strong>\uff1a\u30e8\u30fc\u30ed\u30c3\u30d1\u4eba\u304c18\u30c9\u30eb/\u6642\u3067AI\u30d7\u30ed\u30b8\u30a7\u30af\u30c8\u306b\u767b\u9332\u3001\u958b\u767a\u9014\u4e0a\u56fd\u306b4\u30c9\u30eb/\u6642\u3067\u5916\u6ce8\u3002<strong>Google\u3001Apple\u3001Microsoft\u3001Amazon</strong>\u306e\u30c8\u30ec\u30fc\u30cb\u30f3\u30b0\u30c7\u30fc\u30bf\u306f\u3072\u3069\u3044\u3082\u306e\u3060\u3063\u305f\u3002</p><div class=\"story-label\">\u79c1\u304c\u3057\u305f\u3053\u3068</div><p>\u5831\u544a\u3057\u305f\u3002\u8ab0\u3082\u805e\u304b\u306a\u304b\u3063\u305f\u3002\u81ea\u5206\u306e\u30aa\u30da\u30ec\u30fc\u30b7\u30e7\u30f3\u3092\u69cb\u7bc9\uff1a<strong>\u30e9\u30a4\u30bf\u30fc\u3001\u30c8\u30ec\u30fc\u30ca\u30fc\u3001QC\u30c1\u30fc\u30e0\u3001\u30ea\u30e2\u30fc\u30c8\u30e2\u30cb\u30bf\u30ea\u30f3\u30b0\u3001\u30ab\u30b9\u30bf\u30e0\u30d6\u30e9\u30a6\u30b6\u62e1\u5f35</strong>\u3001\u96c6\u4e2d\u8a66\u9a13\u3002</p><div class=\"impact\">\u539f\u5247\uff1a\u300c\u79c1\u306e\u305b\u3044\u3067\u8ab0\u304b\u304c\u50b7\u3064\u304f\u3088\u308a\u3001\u8ca7\u3057\u3044\u307b\u3046\u304c\u307e\u3057\u300d</div>",
